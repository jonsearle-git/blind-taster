{
  "expo": {
    "name": "Blind Tester",
    "slug": "blind-tester",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0A0B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.blindtester.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Blind Tester uses Bluetooth to connect players in the same room.",
        "NSBluetoothPeripheralUsageDescription": "Blind Tester uses Bluetooth to connect players in the same room.",
        "UIBackgroundModes": [
          "bluetooth-central",
          "bluetooth-peripheral",
          "bluetooth-central",
          "bluetooth-peripheral"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0A0B"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.blindtester.app",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "0813baa4-cee8-410b-83ad-5a742b867110"
      }
    }
  }
}
