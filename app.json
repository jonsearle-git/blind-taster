{
  "expo": {
    "name": "Blind Taster",
    "slug": "blind-taster",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3D1766"
    },
    "scheme": "blindtaster",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.blindtaster.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0A0B"
      },
      "package": "com.blindtaster.app",
      "softwareKeyboardLayoutMode": "pan"
    },
    "extra": {
      "eas": {
        "projectId": "02f06090-71aa-49d8-9bf3-32774456fa3c"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      "expo-camera"
    ],
    "owner": "searlesoft"
  }
}
